{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":semanticCommitsDisabled"],
  "commitMessageAction": "{{currentVersion}} -> {{newVersion}}",
  "commitMessageTopic": "",
  "commitMessageExtra": "",
  "commitMessageSuffix": "",
  "packageRules": [
    {
      "matchDatasources": ["terraform-provider"],
      "commitMessagePrefix": "tofu/{{depName}}:",
      "commitMessageTopic": ""
    },
    {
      "matchDatasources": ["docker"],
      "commitMessagePrefix": "{{ replace '^.*/' '' depName }}:",
      "commitMessageTopic": "",
      "commitMessageExtra": ""
    },
    {
      "matchDatasources": ["helm", "github-tags", "github-releases"],
      "commitMessagePrefix": "{{ depName }}:",
      "commitMessageTopic": ""
    },
    {
      "matchDepNames": ["plex-media-server"],
      "overrideDepName": "plex"
    },
    {
      "matchDepNames": ["fluxcd/flux2"],
      "overrideDepName": "flux"
    }
  ],
  "flux": {
    "managerFilePatterns": [
      "/(?:^|/)gotk-components\\.ya?ml$/",
      "/k8s/.+\\.yaml/"
    ]
  },
  "kubernetes": {
    "managerFilePatterns": [
      "/k8s/02-addons/.+\\.yaml$/",
      "/k8s/03-apps/.+\\.yaml$/"
    ]
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Process CRD dependencies",
      "managerFilePatterns": ["/cluster/.+\\.ya?ml$/"],
      "datasourceTemplate": "{{#if datasource}}{{{datasource}}}{{else}}helm{{/if}}",
      "matchStrings": [
        "registryUrl=(?<registryUrl>\\S+) chart=(?<depName>\\S+)\n.*?(?<currentValue>[^-\\s]*)\n",
        "datasource=(?<datasource>\\S+) image=(?<depName>\\S+)\n.*?-\\s(.*?)\\/(?<currentValue>[^/]+)\\/[^/]+\n"
      ]
    }
  ]
}
